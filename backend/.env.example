# Backend Environment Variables
# Copy this file to /backend/.env and fill in your values

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection String
# For local development:
MONGODB_URI=mongodb://127.0.0.1:27017/insurance-policy-system
# For MongoDB Atlas (production):
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/insurance-policy-system

# JWT Secret (use a strong random string in production)
JWT_SECRET=super_secret_session_jwt_key_987654321

# Frontend URL (for CORS - comma-separated for multiple origins)
FRONTEND_URL=http://localhost:3000
# For production example:
# FRONTEND_URL=https://hdfcinsura.vercel.app
