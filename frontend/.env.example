# Frontend Environment Variables
# Copy this file to /frontend/.env.local and fill in your values

# API Base URL
# For local development (points directly to backend):
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# For local development using Next.js reverse proxy (recommended to avoid CORS):
# NEXT_PUBLIC_API_URL=/api
# BACKEND_API_URL=http://localhost:5000

# For production on Vercel (uses reverse proxy in next.config.js):
# NEXT_PUBLIC_API_URL=/api
# BACKEND_API_URL=https://<your-render-backend>.onrender.com
